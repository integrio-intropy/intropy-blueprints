<Project Sdk="Microsoft.NET.Sdk">

    <Sdk Name="Aspire.AppHost.Sdk" Version="13.4.6" />

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>{{ .projectName }}.SystemHost</RootNamespace>
        <IsAspireHost>true</IsAspireHost>
        <IsPackable>false</IsPackable>
        <UserSecretsId>{{ .name }}-systemhost</UserSecretsId>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Aspire.Hosting.AppHost" Version="13.4.6" />
        <!-- The Intropy.Topology packages must be resolvable from your NuGet feed. -->
        <PackageReference Include="Intropy.Topology.Aspire" Version="0.1.0" />
        <PackageReference Include="Intropy.Topology.Generation" Version="0.1.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../{{ .projectName }}.Contracts/{{ .projectName }}.Contracts.csproj" IsAspireProjectResource="false" />
    </ItemGroup>

</Project>
