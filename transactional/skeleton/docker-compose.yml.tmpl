# Local observability stack for {{ .name }}.
#
# A single grafana/otel-lgtm container: Grafana + Loki (logs) + Tempo (traces)
# + Mimir/Prometheus (metrics) behind a built-in OTLP collector. The console
# job exports to this over OTLP via OTEL_EXPORTER_OTLP_ENDPOINT (see Taskfile
# `run` task) and the data shows up under the `{{ .name | kebabcase }}` service in Grafana.
#
#   task lgtm:up    # start the stack
#   task run        # run the job; telemetry flows to the collector
#   task lgtm:down  # stop the stack
#
# Grafana UI:       http://localhost:3000  (anonymous admin, no login)
# OTLP gRPC ingest: localhost:4317
# OTLP HTTP ingest: localhost:4318

services:
  lgtm:
    image: grafana/otel-lgtm:latest
    container_name: {{ .appId }}-lgtm
    ports:
      - "3000:3000"   # Grafana UI
      - "4317:4317"   # OTLP gRPC
      - "4318:4318"   # OTLP HTTP
    restart: unless-stopped
