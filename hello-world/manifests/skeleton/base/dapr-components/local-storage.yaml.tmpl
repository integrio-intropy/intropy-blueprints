# PLACEHOLDER — replace with the real outbound transport for this integration
# (bindings.sftp, bindings.azure.blobstorage, ...). bindings.localstorage
# writes to the Dapr sidecar's own filesystem, which is ephemeral in a pod:
# files vanish on restart. Keep the component name — the app resolves it via
# Constants.LocalStorageBindingName.
apiVersion: dapr.io/v1alpha1
kind: Component
metadata:
  name: local-storage
spec:
  type: bindings.localstorage
  version: v1
  metadata:
    - name: rootPath
      value: /tmp/intropy/out
scopes:
  - {{ .appId }}
