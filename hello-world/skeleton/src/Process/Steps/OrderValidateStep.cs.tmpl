using {{ .name }}.Model;
using Intropy.Contracts.BusinessIncidentService;
using Intropy.Framework.Blocks.Shared;
using Intropy.Framework.Blocks.TransactionalIntegration.Send.Steps;
using Intropy.Framework.Core.Pipeline.Abstractions.Results;

namespace {{ .name }}.Process.Steps;

public class OrderValidateStep : ValidateStep<OrderIn, Context>
{
    public override Task<(BusinessStepResult<OrderIn> Result, Context Context)> ExecuteAsync(
        OrderIn input, Context context, CancellationToken ct)
    {
        var error = Validate(input);
        if (error is not null)
        {
            var incident = new BusinessIncidentData{Description = "test",Context = new Dictionary<string, string>()};
            return Task.FromResult<(BusinessStepResult<OrderIn>, Context)>(
                (new BusinessStepResult<OrderIn>.Failure(incident), context));
        }

        return Task.FromResult<(BusinessStepResult<OrderIn>, Context)>(
            (new BusinessStepResult<OrderIn>.Success(input), context));
    }

    private static string? Validate(OrderIn order)
    {
        if (string.IsNullOrWhiteSpace(order.OrderId))
            return "OrderId is required";
        if (string.IsNullOrWhiteSpace(order.CustomerId))
            return "CustomerId is required";
        if (order.OrderDate > DateTimeOffset.UtcNow)
            return $"OrderDate {order.OrderDate:O} is in the future";
        if (order.Lines.Count == 0)
            return "Order must contain at least one line";
        return null;
    }
}
