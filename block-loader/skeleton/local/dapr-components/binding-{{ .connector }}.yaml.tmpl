apiVersion: dapr.io/v1alpha1
kind: Component
metadata:
  # Must match Constants.ConnectorBindingName and the component the SystemHost generates for this
  # connector. Standalone it is a localstorage binding; the SystemHost overrides it with the
  # connector's real transport at run time by swapping the components folder.
  name: binding.{{ .connector }}
spec:
  type: bindings.localstorage
  version: v1
  metadata:
    - name: rootPath
      value: "./local/storage/outbound"
