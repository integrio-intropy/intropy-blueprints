// {{ .name }} — an Intropy extractor block. It reads from the {{ .sourceSystem }} external system
// through the "{{ .connectorName | default .sourceSystem }}" connector and publishes onto the
// "{{ .publishesTopic }}" topic. The worker below is deliberately minimal: it reads the identity
// and runtime config the SystemHost's run backend injects, logs them, and exposes an endpoint so
// its Dapr sidecar has an app to talk to. A real worker binds its subscriptions, publishes, and
// connectors from the same INTROPY__CONFIG contract.

var builder = WebApplication.CreateBuilder(args);
var app = builder.Build();

var component = Environment.GetEnvironmentVariable("INTROPY__COMPONENT") ?? "{{ .name }}";
var config = Environment.GetEnvironmentVariable("INTROPY__CONFIG");
app.Logger.LogInformation("Intropy component {Component} started. Runtime config: {Config}", component, config);

app.MapGet("/", () => component);
app.Run();
