using Dapr.Client;
using Dapr.Messaging.PublishSubscribe.Extensions;
using {{ .projectName }}.Configuration;
using {{ .projectName }}.Receive;
using Intropy.Framework.Adapters.File;
using Intropy.Framework.Blocks.TransactionalIntegration.Receive;
using Intropy.Framework.Core.Configuration;
using Intropy.Framework.Hosting.TransactionalIntegration.Job;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Logging;

// {{ .name }} — an Intropy extractor block. It is a console job that reads records waiting at the
// {{ .sourceSystem }} external system through the "{{ .connector }}" connector and publishes each
// raw record onto the "{{ .publishesTopic }}" topic. Standalone it runs entirely on local Dapr
// components (a localstorage source binding + an in-memory pub/sub); under a SystemHost the same
// worker binds to the same component names but the run backend swaps in shared infra (the
// connector's real transport + Redis pub/sub). The job drains the source once and exits.

var services = new ServiceCollection();

services.AddLogging(builder => builder.AddConsole());

services.AddSingleton(_ => new DaprClientBuilder().Build());
services.AddDaprPubSubClient();

services.AddIntropyFramework(x =>
{
    x.ComponentName = Constants.ComponentName;
    x.ServiceNamespace = Constants.ServiceNamespace;
});

services.AddTransactionalIntegration(options =>
{
    options.DaprPubSubName = Constants.PubSubName;
    options.DaprTopicName = Constants.PublishTopic;
});

// The inbound connector this extractor reads from. Standalone it is a localstorage binding reading
// files under ./local/storage/inbound; under a SystemHost the same "binding.{{ .connector }}" name
// resolves to the connector's real transport.
services.AddKeyedSingleton<IFileAdapter>(Constants.SourceFileAdapterKey, (sp, _) =>
    new LocalFileAdapter(
        sp.GetRequiredService<DaprClient>(),
        new FileAdapterOptions(Constants.ConnectorBindingName)));

services.AddSingleton<ISourceLister, SourceLister>();

services.AddReceivePipeline();

var serviceProvider = services.BuildServiceProvider();
var runner = serviceProvider.GetRequiredService<TransactionalIntegrationRunner>();
return await runner.RunAsync();
