using {{ .projectName }}.Configuration;
using Intropy.Contracts.BusinessIncidentService;
using Intropy.Framework.Adapters.File;
using Intropy.Framework.Blocks.Shared;
using Intropy.Framework.Blocks.TransactionalIntegration.Receive;
using Intropy.Framework.Blocks.TransactionalIntegration.Receive.Steps;
using Intropy.Framework.Core.Pipeline.Abstractions.Results;

namespace {{ .projectName }}.Receive;

// Step 1: read the bytes for one source item from the connector.
public class Receiver(IFileAdapter fileAdapter) : ReceiveStep<Context>
{
    public override async Task<(BusinessStepResult<SourceItem> Result, Context Context)> ExecuteAsync(
        SourceItemInfo input, Context context, CancellationToken ct)
    {
        context.Metadata.Add(Constants.ContextKeyFileName, input.Id);

        byte[] data;
        try
        {
            data = await fileAdapter.GetContentAsync(input.Id);
        }
        catch (Exception e)
        {
            var incident = new BusinessIncidentData
            {
                Description = "Failed to get file content",
                Context = new Dictionary<string, string>
                {
                    { "fileName", input.Id },
                    { "exception", e.Message }
                }
            };
            return (new BusinessStepResult<SourceItem>.Failure(incident), context);
        }

        var sourceItem = new SourceItem(input.Id, data);
        return (new BusinessStepResult<SourceItem>.Success(sourceItem), context);
    }
}
